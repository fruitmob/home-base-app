# Home Base — copy to .env and fill in values

# Supabase Postgres — both URLs use the Supavisor pooler host (the db.<ref>.supabase.co
# direct host is IPv6-only and unreachable from most local/CI networks).
# Pooled / transaction mode (port 6543) — Prisma client at runtime
POSTGRES_PRISMA_URL="postgresql://postgres.PROJECT_REF:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Supavisor session mode (port 5432 on the SAME pooler host) — Prisma migrations
POSTGRES_URL_NON_POOLING="postgresql://postgres.PROJECT_REF:PASSWORD@POOLER_HOST:5432/postgres"
DATABASE_URL="${POSTGRES_PRISMA_URL}"

# Supabase REST/Realtime
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Session encryption (generate with: openssl rand -hex 32)
SESSION_SECRET=""

# Seed owner account
SEED_OWNER_EMAIL="owner@homebase.local"
SEED_OWNER_PASSWORD=""

# AWS S3
AWS_REGION="us-east-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET=""

# Resend
RESEND_API_KEY=""
EMAIL_FROM="Home Base <noreply@example.com>"

# Stripe billing (Module 11 Step 4) — leave blank to disable the webhook and billing CTAs
STRIPE_WEBHOOK_SECRET=""
STRIPE_CHECKOUT_URL=""
STRIPE_CUSTOMER_PORTAL_URL=""

# Demo tenant seed (Module 12) — scripts/seed-demo.ts reads this to set staff passwords
SEED_DEMO_PASSWORD=""

# Cron shared secret — Vercel Cron sends this as Authorization: Bearer on scheduled invocations.
# Generate per deployment with: openssl rand -hex 32
CRON_SECRET=""

# Cloudflare Stream
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_STREAM_WEBHOOK_SECRET=""
CLOUDFLARE_STREAM_CUSTOMER_CODE=""
CLOUDFLARE_STREAM_MOCK="false"

GAUGE_PROVIDER="mock"
GAUGE_BASE_URL="http://localhost:11434"
GAUGE_MODEL="gemma3"
GAUGE_EMBEDDING_MODEL="embeddinggemma"
