// MODULE 05: CUSTOMER PORTAL
// ----------------------------------------------------------------------

enum PortalAuthorType {
  CUSTOMER
  STAFF
}

enum PortalUploadStatus {
  NEW
  TRIAGED
  LINKED
}

model PortalToken {
  id         String    @id @default(cuid())
  token      String    @unique
  customerId String?
  vehicleId  String?
  expiresAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle  Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([customerId])
  @@index([vehicleId])
  @@index([expiresAt])
}

model PortalMessage {
  id          String           @id @default(cuid())
  customerId  String
  workOrderId String?
  authorType  PortalAuthorType
  authorId    String?
  body        String           @db.Text
  readAt      DateTime?
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  customer  Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  author    User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([workOrderId])
  @@index([createdAt])
}

