generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  SERVICE_MANAGER
  SERVICE_WRITER
  TECH
  PARTS
  INSPECTOR
  SALES_MANAGER
  SALES_REP
  ACCOUNTANT
  VIEWER
}

enum CustomerType {
  BUSINESS
  INDIVIDUAL
}

enum AddressType {
  BILLING
  SERVICE
  SHIPPING
  MAILING
  OTHER
}

enum VendorType {
  PARTS
  SERVICE
  BOTH
  OTHER
}

enum VehicleNoteType {
  GENERAL
  CONDITION
  SERVICE_HISTORY
  WARNING
}

enum LeadStatus {
  NEW
  WORKING
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

enum LeadSource {
  WEB
  PHONE
  EMAIL
  REFERRAL
  WALK_IN
  EVENT
  OTHER
}

enum OpportunityStage {
  NEW
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
  NOTE
}

enum ActivityStatus {
  OPEN
  COMPLETED
  CANCELED
}

enum CaseStatus {
  OPEN
  WAITING
  RESOLVED
  CANCELED
}

enum CasePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum VideoStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD_PARTS
  ON_HOLD_DELAY
  QC
  READY_TO_BILL
  CLOSED
}

enum WorkOrderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum WorkOrderLineType {
  LABOR
  PART
  SUBLET
  FEE
  NOTE
}

enum WorkOrderLineStatus {
  OPEN
  APPROVED
  IN_PROGRESS
  COMPLETE
  CANCELED
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  LOCKED
}

enum TimeEntryEventType {
  START
  PAUSE
  RESUME
  STOP
  SUBMIT
  APPROVE
  REJECT
  ADJUST
  LOCK
}

enum TimePauseReason {
  WAITING_PARTS
  WAITING_CUSTOMER
  TECH_BREAK
  SHOP_DELAY
  OTHER
}

enum PartReservationStatus {
  ACTIVE
  ISSUED
  RELEASED
  CANCELED
}

enum PartTransactionType {
  RECEIVE
  ADJUST
  RESERVE
  RELEASE_RESERVATION
  ISSUE
  RETURN_TO_STOCK
}

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  DECLINED
  EXPIRED
  CONVERTED
}

enum ChangeOrderStatus {
  DRAFT
  SENT
  APPROVED
  DECLINED
  CANCELED
}

enum InspectionType {
  ARRIVAL
  PDI
}

enum InspectionStatus {
  DRAFT
  COMPLETE
}

enum InspectionItemResult {
  PASS
  FAIL
  ATTENTION
  NOT_APPLICABLE
}

enum WarrantyClaimStatus {
  OPEN
  SUBMITTED
  APPROVED
  DENIED
  RECOVERED
  CLOSED
}

enum GaugeMessageRole {
  USER
  ASSISTANT
  TOOL
}

enum GaugeToolCallStatus {
  REQUESTED
  COMPLETED
  BLOCKED
  FAILED
}

enum GaugeRetrievalSourceType {
  CUSTOMER
  VEHICLE
  PART
  ESTIMATE
  CASE
  KB_ARTICLE
  VIDEO
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  role                    Role
  deletedAt               DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  sessions                Session[]
  auditLogs               AuditLog[]               @relation("AuditActor")
  preference              UserPreference?
  savedFilters            SavedFilter[]
  vehicleNotes            VehicleNote[]            @relation("VehicleNoteAuthor")
  mileageReadings         VehicleMileageReading[]  @relation("VehicleMileageRecorder")
  ownedLeads              Lead[]                   @relation("LeadOwner")
  ownedOpportunities      Opportunity[]            @relation("OpportunityOwner")
  ownedActivities         Activity[]               @relation("ActivityOwner")
  openedCases             Case[]                   @relation("CaseOpener")
  assignedCases           Case[]                   @relation("CaseAssignee")
  createdQuotes           Quote[]                  @relation("QuoteCreator")
  salesGoals              SalesGoal[]
  serviceWriterWorkOrders WorkOrder[]              @relation("WorkOrderServiceWriter")
  assignedWorkOrders      WorkOrder[]              @relation("WorkOrderAssignedTech")
  workOrderStatusChanges  WorkOrderStatusHistory[] @relation("WorkOrderStatusChanger")
  timeEntries             TimeEntry[]              @relation("TimeEntryTech")
  approvedTimeEntries     TimeEntry[]              @relation("TimeEntryApprover")
  timeEntryEvents         TimeEntryEvent[]         @relation("TimeEntryEventTech")
  createdTimeEntryEvents  TimeEntryEvent[]         @relation("TimeEntryEventCreator")
  partReservations        PartReservation[]        @relation("PartReservationCreator")
  partTransactions        PartTransaction[]        @relation("PartTransactionCreator")
  createdEstimates        Estimate[]               @relation("EstimateCreator")
  requestedChangeOrders   ChangeOrder[]            @relation("ChangeOrderRequester")
  performedInspections    ArrivalInspection[]      @relation("InspectionPerformer")
  portalMessages          PortalMessage[]
  authoredArticles        KbArticle[]              @relation("ArticleAuthor")
  editedArticleVersions   KbArticleVersion[]       @relation("ArticleVersionEditor")
  receivedTraining        TrainingAssignment[]     @relation("TrainingAssignedTo")
  assignedTraining        TrainingAssignment[]     @relation("TrainingAssignedBy")
  uploadedVideos            Video[]                  @relation("VideoUploader")
  gaugeConversations        GaugeConversation[]
  gaugeToolCalls            GaugeToolCall[]
  initiatedImpersonations   Impersonation[]          @relation("ImpersonationActor")
  receivedImpersonations    Impersonation[]          @relation("ImpersonationTarget")
  dashboardLayouts          DashboardLayout[]
  widgetPreferences         WidgetPreference[]
}

model Session {
  // Session ids are generated by the auth layer from secure random bytes.
  id         String   @id
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  ipAddress  String?
  userAgent  String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  beforeJson  Json?
  afterJson   Json?
  ipAddress   String?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model UserPreference {
  userId             String   @id
  theme              String?
  defaultLandingPage String?
  tableDensity       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedFilter {
  id        String   @id @default(cuid())
  userId    String
  scope     String
  name      String
  queryJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope, name])
  @@index([userId, scope])
}

model DashboardLayout {
  id            String   @id @default(cuid())
  userId        String
  scope         String
  widgetOrder   Json
  hiddenWidgets Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope])
  @@index([userId])
}

model WidgetPreference {
  id           String   @id @default(cuid())
  userId       String
  widgetId     String
  settingsJson Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, widgetId])
  @@index([userId])
}

enum EmailSendStatus {
  QUEUED
  SENT
  SIMULATED
  FAILED
}

model EmailTemplate {
  id             String       @id @default(cuid())
  key            String       @unique
  label          String
  description    String?
  subject        String
  html           String
  text           String
  variablesJson  Json
  version        Int          @default(1)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  sends          EmailSend[]

  @@index([deletedAt])
}

model EmailSend {
  id                String           @id @default(cuid())
  templateKey       String
  templateVersion   Int
  recipientEmail    String
  subject           String
  status            EmailSendStatus  @default(QUEUED)
  providerMessageId String?
  errorMessage      String?
  variablesJson     Json
  createdAt         DateTime         @default(now())
  template          EmailTemplate?   @relation(fields: [templateKey], references: [key], onUpdate: NoAction, onDelete: SetNull)

  @@index([templateKey, createdAt])
  @@index([recipientEmail, createdAt])
  @@index([status])
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCEEDED
  FAILED
  PERMANENTLY_FAILED
}

model WebhookEndpoint {
  id              String            @id @default(cuid())
  label           String
  url             String
  secret          String
  enabled         Boolean           @default(true)
  eventTypesJson  Json
  createdByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  deliveries      WebhookDelivery[]

  @@index([enabled])
  @@index([deletedAt])
}

model WebhookDelivery {
  id             String                @id @default(cuid())
  endpointId     String
  eventType      String
  eventId        String
  payloadJson    Json
  status         WebhookDeliveryStatus @default(PENDING)
  attemptCount   Int                   @default(0)
  maxAttempts    Int                   @default(6)
  lastAttemptAt  DateTime?
  nextAttemptAt  DateTime              @default(now())
  responseStatus Int?
  responseBody   String?
  errorMessage   String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  endpoint       WebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, createdAt])
  @@index([status, nextAttemptAt])
  @@index([eventType, createdAt])
}

model ApiKey {
  id              String         @id @default(cuid())
  label           String
  hashedKey       String         @unique
  lastFour        String
  scopesJson      Json
  createdByUserId String?
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  usage           ApiKeyUsage[]

  @@index([revokedAt])
  @@index([createdByUserId])
}

model ApiKeyUsage {
  id           String   @id @default(cuid())
  apiKeyId     String
  windowStart  DateTime
  requestCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  apiKey       ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, windowStart])
  @@index([windowStart])
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  UNPAID
  PAUSED
}

model Subscription {
  id                   String             @id @default(cuid())
  stripeSubscriptionId String             @unique
  stripeCustomerId     String
  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  cancelAt             DateTime?
  canceledAt           DateTime?
  latestEventAt        DateTime           @default(now())
  rawJson              Json
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([status])
  @@index([stripeCustomerId])
}

model BillingEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique
  eventType     String
  payloadJson   Json
  receivedAt    DateTime  @default(now())
  processedAt   DateTime?
  errorMessage  String?

  @@index([eventType, receivedAt])
}

model Customer {
  id                  String              @id @default(cuid())
  customerType        CustomerType        @default(BUSINESS)
  displayName         String
  companyName         String?
  firstName           String?
  lastName            String?
  email               String?
  phone               String?
  website             String?
  taxExempt           Boolean             @default(false)
  taxExemptId         String?
  defaultPaymentTerms String?
  isWalkIn            Boolean             @default(false)
  notes               String?
  defaultPricebookId  String?
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  contacts            Contact[]
  addresses           Address[]
  vehicles            Vehicle[]
  defaultPricebook    Pricebook?          @relation("CustomerDefaultPricebook", fields: [defaultPricebookId], references: [id], onDelete: SetNull)
  leads               Lead[]              @relation("LeadCustomer")
  convertedFromLeads  Lead[]              @relation("LeadConvertedCustomer")
  opportunities       Opportunity[]
  activities          Activity[]
  cases               Case[]
  quotes              Quote[]
  workOrders          WorkOrder[]
  videos              Video[]
  estimates           Estimate[]
  arrivalInspections  ArrivalInspection[]
  portalTokens        PortalToken[]
  portalMessages      PortalMessage[]
  portalUploads       PortalUpload[]

  @@index([displayName])
  @@index([email])
  @@index([phone])
  @@index([defaultPricebookId])
  @@index([deletedAt])
}

model Contact {
  id          String    @id @default(cuid())
  customerId  String?
  vendorId    String?
  firstName   String?
  lastName    String?
  displayName String
  title       String?
  email       String?
  phone       String?
  mobile      String?
  isPrimary   Boolean   @default(false)
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vendor      Vendor?   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([vendorId])
  @@index([email])
  @@index([phone])
  @@index([deletedAt])
}

model Address {
  id         String      @id @default(cuid())
  customerId String?
  vendorId   String?
  type       AddressType @default(OTHER)
  label      String?
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String?
  country    String      @default("US")
  isPrimary  Boolean     @default(false)
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vendor     Vendor?     @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([vendorId])
  @@index([type])
  @@index([deletedAt])
}

model Vehicle {
  id                 String                  @id @default(cuid())
  customerId         String
  vin                String?
  normalizedVin      String?                 @unique
  year               Int?
  make               String?
  model              String?
  trim               String?
  unitNumber         String?
  licensePlate       String?
  licenseState       String?
  currentMileage     Int?
  color              String?
  notes              String?
  deletedAt          DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  customer           Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleNotes       VehicleNote[]
  mileageReadings    VehicleMileageReading[]
  opportunities      Opportunity[]
  activities         Activity[]
  cases              Case[]
  quotes             Quote[]
  workOrders         WorkOrder[]
  estimates          Estimate[]
  videos             Video[]
  arrivalInspections ArrivalInspection[]
  portalTokens       PortalToken[]

  @@index([customerId])
  @@index([unitNumber])
  @@index([licensePlate])
  @@index([deletedAt])
}

model VehicleNote {
  id           String          @id @default(cuid())
  vehicleId    String
  authorUserId String?
  type         VehicleNoteType @default(GENERAL)
  body         String
  createdAt    DateTime        @default(now())
  vehicle      Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  authorUser   User?           @relation("VehicleNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([authorUserId])
  @@index([createdAt])
}

model VehicleMileageReading {
  id               String   @id @default(cuid())
  vehicleId        String
  value            Int
  source           String
  recordedAt       DateTime
  recordedByUserId String?
  note             String?
  createdAt        DateTime @default(now())
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  recordedByUser   User?    @relation("VehicleMileageRecorder", fields: [recordedByUserId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([recordedByUserId])
  @@index([recordedAt])
}

model Vendor {
  id                  String            @id @default(cuid())
  vendorType          VendorType        @default(PARTS)
  name                String
  accountNumber       String?
  email               String?
  phone               String?
  website             String?
  defaultPaymentTerms String?
  taxId               String?
  notes               String?
  deletedAt           DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  contacts            Contact[]
  addresses           Address[]
  parts               Part[]
  partTransactions    PartTransaction[]
  warrantyClaims      WarrantyClaim[]

  @@index([name])
  @@index([email])
  @@index([phone])
  @@index([deletedAt])
}

model Lead {
  id                     String       @id @default(cuid())
  status                 LeadStatus   @default(NEW)
  source                 LeadSource   @default(OTHER)
  companyName            String?
  firstName              String?
  lastName               String?
  displayName            String
  email                  String?
  phone                  String?
  interest               String?
  estimatedValue         Decimal?     @db.Decimal(18, 4)
  notes                  String?
  ownerUserId            String?
  customerId             String?
  convertedOpportunityId String?      @unique
  convertedCustomerId    String?
  convertedAt            DateTime?
  deletedAt              DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  ownerUser              User?        @relation("LeadOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  customer               Customer?    @relation("LeadCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  convertedOpportunity   Opportunity? @relation("LeadConvertedOpportunity", fields: [convertedOpportunityId], references: [id], onDelete: SetNull)
  convertedCustomer      Customer?    @relation("LeadConvertedCustomer", fields: [convertedCustomerId], references: [id], onDelete: SetNull)
  activities             Activity[]

  @@index([status])
  @@index([source])
  @@index([ownerUserId])
  @@index([customerId])
  @@index([deletedAt])
  @@index([createdAt])
}

model Opportunity {
  id                String           @id @default(cuid())
  customerId        String
  vehicleId         String?
  ownerUserId       String?
  name              String
  stage             OpportunityStage @default(NEW)
  amount            Decimal          @default(0) @db.Decimal(18, 4)
  probability       Int              @default(0)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  lossReason        String?
  notes             String?
  deletedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  customer          Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle           Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  ownerUser         User?            @relation("OpportunityOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  convertedFromLead Lead?            @relation("LeadConvertedOpportunity")
  activities        Activity[]
  quotes            Quote[]
  workOrders        WorkOrder[]
  estimates         Estimate[]

  @@index([customerId])
  @@index([ownerUserId])
  @@index([stage])
  @@index([expectedCloseDate])
  @@index([closedAt])
  @@index([deletedAt])
}

model Activity {
  id            String         @id @default(cuid())
  type          ActivityType
  status        ActivityStatus @default(OPEN)
  subject       String
  body          String?
  dueAt         DateTime?
  completedAt   DateTime?
  ownerUserId   String?
  leadId        String?
  opportunityId String?
  customerId    String?
  vehicleId     String?
  caseId        String?
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  ownerUser     User?          @relation("ActivityOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  lead          Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunity   Opportunity?   @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  customer      Customer?      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle       Vehicle?       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  case          Case?          @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
  @@index([leadId])
  @@index([opportunityId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([caseId])
  @@index([dueAt])
  @@index([status])
  @@index([deletedAt])
}

model Case {
  id              String          @id @default(cuid())
  customerId      String
  vehicleId       String?
  openedByUserId  String?
  assignedUserId  String?
  status          CaseStatus      @default(OPEN)
  priority        CasePriority    @default(NORMAL)
  subject         String
  description     String?
  resolvedAt      DateTime?
  resolutionNotes String?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  customer        Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle         Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  openedByUser    User?           @relation("CaseOpener", fields: [openedByUserId], references: [id], onDelete: SetNull)
  assignedUser    User?           @relation("CaseAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  activities      Activity[]
  warrantyClaims  WarrantyClaim[]

  @@index([customerId])
  @@index([vehicleId])
  @@index([assignedUserId])
  @@index([status])
  @@index([priority])
  @@index([deletedAt])
}

model Product {
  id               String                  @id @default(cuid())
  sku              String                  @unique
  name             String
  description      String?
  family           String?
  isLabor          Boolean                 @default(false)
  taxable          Boolean                 @default(true)
  active           Boolean                 @default(true)
  defaultUnitPrice Decimal                 @default(0) @db.Decimal(18, 4)
  defaultCost      Decimal?                @db.Decimal(18, 4)
  deletedAt        DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  pricebookEntries PricebookEntry[]
  quoteLines       QuoteLineItem[]
  templateLines    QuoteTemplateLineItem[]
  inventoryPart    Part?                   @relation("PartProduct")
  workOrderLines   WorkOrderLineItem[]
  estimateLines    EstimateLineItem[]
  changeOrderLines ChangeOrderLineItem[]
  woTemplateLines  WoTemplateLineItem[]

  @@index([family])
  @@index([active])
  @@index([deletedAt])
}

model Pricebook {
  id                  String           @id @default(cuid())
  name                String
  description         String?
  isDefault           Boolean          @default(false)
  active              Boolean          @default(true)
  deletedAt           DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  entries             PricebookEntry[]
  defaultForCustomers Customer[]       @relation("CustomerDefaultPricebook")
  quotes              Quote[]

  @@index([isDefault])
  @@index([active])
  @@index([deletedAt])
}

model PricebookEntry {
  id            String    @id @default(cuid())
  pricebookId   String
  productId     String
  unitPrice     Decimal   @db.Decimal(18, 4)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  pricebook     Pricebook @relation(fields: [pricebookId], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([pricebookId])
  @@index([productId])
  @@index([deletedAt])
}

model Quote {
  id              String          @id @default(cuid())
  quoteNumber     String          @unique
  version         Int             @default(1)
  parentQuoteId   String?
  customerId      String
  vehicleId       String?
  opportunityId   String?
