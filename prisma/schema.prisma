  id          String             @id @default(cuid())
  customerId  String
  workOrderId String?
  s3Key       String
  fileName    String
  fileType    String
  fileSize    Int
  status      PortalUploadStatus @default(NEW)
  deletedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  customer  Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([workOrderId])
}

model EstimateApproval {
  id         String   @id @default(cuid())
  estimateId String   @unique
  ipAddress  String?
  userAgent  String?
  approvedAt DateTime @default(now())
  signature  String?

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------------------------------------
// KNOWLEDGE BASE & TRAINING 
// --------------------------------------------------------------------------------------

model KbCategory {
  id        String       @id @default(cuid())
  name      String
  parentId  String?
  parent    KbCategory?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children  KbCategory[] @relation("CategoryToCategory")
  deletedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  articles KbArticle[]
}

enum KbArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model KbArticle {
  id         String          @id @default(cuid())
  title      String
  slug       String          @unique
  body       String          @db.Text
  categoryId String?
  authorId   String
  status     KbArticleStatus @default(DRAFT)
  deletedAt  DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  category KbCategory? @relation(fields: [categoryId], references: [id])
  author   User        @relation("ArticleAuthor", fields: [authorId], references: [id])

  attachments KbAttachment[]
  versions    KbArticleVersion[]
  assignments TrainingAssignment[]
}

model KbArticleVersion {
  id             String   @id @default(cuid())
  articleId      String
  body           String   @db.Text
  editedByUserId String
  createdAt      DateTime @default(now())

  article      KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  editedByUser User      @relation("ArticleVersionEditor", fields: [editedByUserId], references: [id])
}

model KbAttachment {
  id        String   @id @default(cuid())
  articleId String
  s3Key     String
  fileName  String
  createdAt DateTime @default(now())

  article KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model TrainingAssignment {
  id           String    @id @default(cuid())
  assignedToId String
  assignedById String
  articleId    String
  dueAt        DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignedTo User      @relation("TrainingAssignedTo", fields: [assignedToId], references: [id])
  assignedBy User      @relation("TrainingAssignedBy", fields: [assignedById], references: [id])
  article    KbArticle @relation(fields: [articleId], references: [id])

  completion TrainingCompletion?
}

model TrainingCompletion {
  assignmentId String   @id
  completedAt  DateTime @default(now())

  assignment TrainingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model Video {
  id               String      @id @default(cuid())
  cloudflareId     String      @unique
  status           VideoStatus @default(UPLOADING)
  title            String
  description      String?     @db.Text
  durationSeconds  Int?
  thumbnailUrl     String?
  uploadedByUserId String
  workOrderId      String?
  vehicleId        String?
  customerId       String?
  deletedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  uploadedByUser User       @relation("VideoUploader", fields: [uploadedByUserId], references: [id])
  workOrder      WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  vehicle        Vehicle?   @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  customer       Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)

  shareLinks VideoShareLink[]

  @@index([cloudflareId])
  @@index([workOrderId])
  @@index([vehicleId])
  @@index([customerId])
  @@index([uploadedByUserId])
  @@index([deletedAt])
}

model VideoShareLink {
  id        String    @id @default(cuid())
  videoId   String
  token     String    @unique
  expiresAt DateTime?
  viewCount Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([token])
}

// --------------------------------------------------------------------------------------
// MODULE 08: GAUGE AI ASSISTANT
// --------------------------------------------------------------------------------------

model GaugeConversation {
  id         String    @id @default(cuid())
  userId     String
  title      String
  provider   String
  model      String
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  GaugeMessage[]
  toolCalls GaugeToolCall[]

  @@index([userId])
  @@index([archivedAt])
  @@index([createdAt])
}

model GaugeMessage {
  id             String           @id @default(cuid())
  conversationId String
  role           GaugeMessageRole
  content        String           @db.Text
  toolName       String?
  toolInputJson  Json?
  toolOutputJson Json?
  createdAt      DateTime         @default(now())

  conversation GaugeConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolCalls    GaugeToolCall[]

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
}

model GaugeToolCall {
  id             String              @id @default(cuid())
  conversationId String
  messageId      String?
  userId         String
  toolName       String
  status         GaugeToolCallStatus @default(REQUESTED)
  inputJson      Json
  outputJson     Json?
  error          String?
  writeRequested Boolean             @default(false)
  writePerformed Boolean             @default(false)
  createdAt      DateTime            @default(now())
  completedAt    DateTime?

  conversation GaugeConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      GaugeMessage?     @relation(fields: [messageId], references: [id], onDelete: SetNull)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([messageId])
  @@index([userId])
  @@index([toolName])
  @@index([status])
  @@index([createdAt])
}

// --------------------------------------------------------------------------------------
// MODULE 09: ADMIN TOOLS
// --------------------------------------------------------------------------------------

model Impersonation {
  id           String    @id @default(cuid())
  actorUserId  String
  targetUserId String
  reason       String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  ipAddress    String?
  createdAt    DateTime  @default(now())

  actorUser  User @relation("ImpersonationActor",  fields: [actorUserId],  references: [id], onDelete: Cascade)
  targetUser User @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([endedAt])
  @@index([startedAt])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([enabled])
}

model GaugeRetrievalIndex {
  id              String                   @id @default(cuid())
  sourceType      GaugeRetrievalSourceType
  sourceId        String
  title           String
  summary         String?                  @db.Text
  content         String                   @db.Text
  href            String?
  metadata        Json?
  sourceUpdatedAt DateTime?
  indexedAt       DateTime                 @default(now())

  @@unique([sourceType, sourceId])
  @@index([sourceType])
  @@index([sourceUpdatedAt])
  @@index([indexedAt])
}
